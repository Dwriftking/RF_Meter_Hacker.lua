--- 2. Analyzer Module
-- Parses the raw signals to deduce protocols and potential data fields.
function analyze_data(raw_packets)
    print("\n[ANALYZER] --- Decoding &amp; Pattern Matching ---")
    local detected = {}
    local payload_guess = ""

    for i, packet in ipairs(raw_packets) do
        -- *** CUSTOM PARSING LOGIC GOES HERE ***
        if string.find(packet.Data, "IEC-62056") then
            table.insert(detected, "IEC 62056 (Protocol Match)")
            -- Example extraction: Assume voltage is always preceded by 'V:'
            local v_match = packet.Data:match("V:(%d*%.?d)")
            if v_match then
                payload_guess = string.format("V:%s", v_match)
            end
        elseif string.find(packet.Type, "NFC") then
             table.insert(detected, "NFC Reader Active.")
        end
    end

    return { Protocols = detected, PayloadGuess = payload_guess }
end


